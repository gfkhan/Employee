@page "/employees"
@using System.Xml.Serialization
@using System.Xml
@using System.IO
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Employees</PageTitle>

<h1>Employees</h1>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">
        <strong>Error:</strong> @_errorMessage
    </div>
}
else if (_employees is null)
{
    <p><em>Loading...</em></p>
}
else if (_employees.Length == 0)
{
    <p>No employees found.</p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleXmlView">
            @(_showXml ? "Hide XML" : "Show as XML")
        </button>
    </div>

    @if (_showXml)
    {
        <pre class="border rounded p-3 bg-light" style="max-height:500px; overflow:auto;">
            <code>@_xmlString</code>
        </pre>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Job Title</th>
                    <th>Hourly Rate</th>
                    <th>Hire Date</th>
                    <th>Addresses</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in _employees)
                {
                    <tr>
                        <td>@emp.Id</td>
                        <td>@emp.FirstName @emp.LastName</td>
                        <td>@emp.Email</td>
                        <td>@emp.PhoneNumber</td>
                        <td>@emp.JobTitle</td>
                        <td>@emp.HourlyRate.ToString("C")</td>
                        <td>@emp.HireDate.ToShortDateString()</td>
                        <td>
                            @if (emp.Addresses is { Count: > 0 })
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (var addr in emp.Addresses)
                                    {
                                        <li>
                                            <strong>@addr.AddressTypeName:</strong>
                                            @addr.Street, @addr.City, @addr.State @addr.ZipCode, @addr.Country
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private EmployeeDto[]? _employees;
    private string? _errorMessage;
    private bool _showXml;
    private string? _xmlString;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // The named HttpClient auto-attaches the Bearer token
            _employees = await Http.GetFromJsonAsync<EmployeeDto[]>("api/employees");
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Token expired or missing — redirect to login
            ex.Redirect();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to load employees: {ex.Message}";
        }
    }

    private void ToggleXmlView()
    {
        _showXml = !_showXml;

        if (_showXml && _xmlString is null && _employees is not null)
        {
            _xmlString = SerializeToXml(_employees);
        }
    }

    private static string SerializeToXml(EmployeeDto[] employees)
    {
        // Wrap array in a root container for clean XML output
        // The root element must be a class, not the list itself.
        var wrapper = new EmployeeListXml { Employees = employees.ToList() };

        var serializer = new XmlSerializer(typeof(EmployeeListXml));
        var settings = new XmlWriterSettings
        {
            Indent = true,
            OmitXmlDeclaration = false,
            NewLineOnAttributes = false
        };

        using var stringWriter = new StringWriter();
        using var xmlWriter = XmlWriter.Create(stringWriter, settings);
        serializer.Serialize(xmlWriter, wrapper);
        return stringWriter.ToString();
    }

    /// <summary>
    /// Wrapper class so XmlSerializer produces a clean root element.
    /// </summary>
    [XmlRoot("Employees")]
    public class EmployeeListXml
    {
        // The List<T> is a public property of the root class.
        //[XmlArray("Books")] // Optional: Renames the array container element to "Books"
       // [XmlArrayItem("Book")] // Optional: Renames each item element to "Book"
        [XmlElement("Employee")]
        public List<EmployeeDto> Employees { get; set; } = new();
    }
}